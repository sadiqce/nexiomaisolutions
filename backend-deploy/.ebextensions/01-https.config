option_settings:
  # Node.js environment configuration
  aws:elasticbeanstalk:application:environment:
    NODE_ENV: production
    PORT: 3001
  
  # Elastic Beanstalk health check configuration
  aws:elasticbeanstalk:environment:process:default:
    HealthCheckPath: /health
    HealthCheckInterval: 30
    HealthCheckTimeout: 5
    HealthyThresholdCount: 3
    UnhealthyThresholdCount: 5
  
  # Configure load balancer to accept both HTTP and HTTPS
  aws:elbv2:listener:default:
    Protocol: HTTP
  
  aws:elbv2:listener:443:
    Protocol: HTTPS

files:
  "/opt/elasticbeanstalk/tasks/bundlelogs.d/01_nodejs.conf":
    mode: "000755"
    owner: root
    group: root
    content: |
      /var/log/nodejs/*

commands:
  01_npm_install:
    command: |
      cd /var/app/current
      npm install --production 2>&1
    ignoreErrors: false
  02_verify_packages:
    command: |
      cd /var/app/current
      npm list selfsigned express cors 2>&1
    ignoreErrors: true
