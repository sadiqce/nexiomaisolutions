option_settings:
  aws:elasticbeanstalk:application:environment:
    NODE_ENV: production
    PORT: 8080
    FRONTEND_URL: https://nexiomaisolutions.com
  
  aws:elasticbeanstalk:environment:process:default:
    HealthCheckPath: /health
  
  aws:elbv2:listener:default:
    Protocol: HTTP
  
  aws:elbv2:listener:443:
    Protocol: HTTPS
    SSLCertificateArns: REPLACE_WITH_YOUR_CERTIFICATE_ARN_HERE
